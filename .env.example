# Environment Configuration for Enterprise E2E Test Platform

# Test Environment (local, docker, ci)
TEST_ENV=local

# Service URLs
UI_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001
KAFKA_URL=http://localhost:3003

# API Configuration
API_TIMEOUT=30000
RETRY_COUNT=3
RETRY_DELAY=1000

# Test Execution
PARALLEL_TEST_WORKERS=4

# Logging
LOG_LEVEL=info

# Node Environment
NODE_ENV=development

# Service Ports
FRONTEND_PORT=3000
API_PORT=3001
KAFKA_PORT=3003

# Database (if applicable)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=testdb
DB_USER=testuser
DB_PASSWORD=testpass

# JWT Secret
SECRET_KEY=test-secret-key-12345

# CI/CD
CI=false

# Monitoring URLs
GRAFANA_URL=http://localhost:3000
PROMETHEUS_URL=http://localhost:9090
